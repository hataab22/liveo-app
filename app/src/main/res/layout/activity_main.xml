<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/liveo_dark"
        android:padding="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Liveo"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/liveo_purple" />

            <TextView
                android:id="@+id/expiryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="متبقي: 30 يوم"
                android:textSize="12sp"
                android:textColor="@color/success"
                android:background="@color/liveo_gray"
                android:padding="6dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/input_background"
            android:queryHint="ابحث عن قناة..."
            android:iconifiedByDefault="false" />
    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/liveo_dark"
        app:tabTextColor="@color/light_gray"
        app:tabSelectedTextColor="@color/white"
        app:tabIndicatorColor="@color/liveo_cyan"
        app:tabIndicatorHeight="3dp" />

    <!-- ViewPager (تم التغيير من ViewPager2 إلى ViewPager) -->
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
